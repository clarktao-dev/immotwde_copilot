{
  "name": "immotwde",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "sanity:install": "cd sanity && npm install",
    "sanity:studio": "cd sanity && sanity start",
    "sanity:deploy": "cd sanity && sanity deploy",
    "test": "echo \"No tests configured\" && exit 0",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md}": [
      "npm run format --if-present",
      "npm run lint --if-present --fix",
      "git add"
    ]
  },
  "dependencies": {
    "@sanity/client": "^5.4.2",
    "@sendgrid/mail": "^8.1.6",
    "build": "^0.1.4",
    "mapbox-gl": "^3.19.0",
    "next": "16.1.6",
    "next-sanity": "^12.1.0",
    "node-fetch": "^3.3.2",
    "npm": "^11.11.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "run": "^1.5.0",
    "stripe": "^12.18.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mapbox__point-geometry": "^1.0.87",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^8.0.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
